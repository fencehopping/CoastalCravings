---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import OfferingCard from '../components/OfferingCard.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import HowItWorks from '../components/HowItWorks.astro';
import CTASection from '../components/CTASection.astro';
import Button from '../components/Button.astro';
import { offerings } from '../data/offerings';
---

<Layout>
  <Hero />

  <section class="py-16 sm:py-24">
    <div class="container-page">
      <SectionHeading
        eyebrow="Offerings"
        title="Boards for every kind of gathering"
        copy="From small beach-night boxes to styled grazing tables, every spread is built around your guest count, occasion, and table."
        align="center"
      />
      <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        {offerings.map((offering) => <OfferingCard offering={offering} />)}
      </div>
    </div>
  </section>

  <section class="bg-shell py-16 sm:py-24">
    <div class="container-page">
      <div class="mb-10 flex flex-col justify-between gap-6 sm:flex-row sm:items-end">
        <SectionHeading eyebrow="Gallery" title="Styled for real South Shore moments" copy="A preview of boards, boxes, grazing tables, and seasonal spreads." />
        <Button href="/gallery" variant="secondary">View gallery</Button>
      </div>
      <GalleryGrid limit={6} />
    </div>
  </section>

  <section class="py-16 sm:py-24">
    <div class="container-page">
      <div class="mb-10 flex flex-col justify-between gap-6 lg:flex-row lg:items-end">
        <SectionHeading eyebrow="How it works" title="Simple planning, beautiful results" copy="Start with the basics and we will guide sizing, styling, and next steps." />
        <Button href="/how-it-works" variant="ghost">See the process</Button>
      </div>
      <HowItWorks />
    </div>
  </section>

  <section class="bg-cream py-16">
    <div class="container-page">
      <div class="grid items-center gap-8 rounded-lg border border-harbor/10 bg-white p-6 shadow-sm md:grid-cols-[1fr_auto] md:p-10">
        <div>
          <p class="text-xs font-bold uppercase text-cranberry">Instagram</p>
          <h2 class="mt-3 font-serif text-4xl font-semibold text-ink">Follow the latest boards and seasonal openings.</h2>
          <p class="mt-3 text-ink/68">Find recent work, limited holiday menus, and local availability through @coastalcravingsma.</p>
        </div>
        <Button href="https://www.instagram.com/coastalcravingsma/" variant="secondary">Visit Instagram</Button>
      </div>
    </div>
  </section>

  <CTASection />
</Layout>
