---
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import InquiryForm from '../components/InquiryForm.astro';
---

<Layout title="Request a Board | Coastal Cravings">
  <section class="bg-shell py-16 sm:py-24">
    <div class="container-page grid gap-10 lg:grid-cols-[0.75fr_1fr]">
      <div>
        <SectionHeading
          eyebrow="Request a Board"
          title="Tell us what you are planning"
          copy="Share your date, guest count, town, and the type of spread you have in mind. This form is structured for a future Tally, Fillout, Airtable, Resend, or serverless endpoint."
        />
        <div class="mt-8 overflow-hidden rounded-lg border border-harbor/10 bg-white shadow-sm">
          <img class="aspect-[4/3] w-full object-cover" src="/images/charcuterie-box.jpg" alt="Coastal charcuterie box with fruit, cheese, crackers, and sweets" />
        </div>
      </div>
      <InquiryForm />
    </div>
  </section>
</Layout>
