---
import { faqs } from '../data/faqs';
---

<div class="divide-y divide-harbor/10 overflow-hidden rounded-lg border border-harbor/10 bg-white">
  {faqs.map((faq, index) => (
    <details class="group" open={index === 0}>
      <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-5 font-semibold text-ink sm:px-7">
        <span>{faq.question}</span>
        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-shell text-harbor transition group-open:rotate-45">+</span>
      </summary>
      <div class="px-5 pb-6 text-sm leading-6 text-ink/68 sm:px-7">
        {faq.answer}
      </div>
    </details>
  ))}
</div>
