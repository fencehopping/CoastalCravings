---
import GalleryItem from './GalleryItem.astro';
import { gallery } from '../data/gallery';

interface Props {
  limit?: number;
}

const { limit } = Astro.props;
const items = typeof limit === 'number' ? gallery.slice(0, limit) : gallery;
---

<div class="columns-1 gap-5 sm:columns-2 lg:columns-3 [&>*]:mb-5">
  {items.map((item) => <GalleryItem item={item} />)}
</div>
