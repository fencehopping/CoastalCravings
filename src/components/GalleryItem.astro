---
import { withBase } from '../utils/path';

interface Props {
  item: {
    image: string;
    alt: string;
    category: string;
    caption?: string;
  };
}

const { item } = Astro.props;
---

<figure class="group break-inside-avoid overflow-hidden rounded-lg border border-harbor/10 bg-white shadow-sm">
  <img class="w-full object-cover transition duration-500 group-hover:scale-[1.03]" src={withBase(item.image)} alt={item.alt} loading="lazy" />
  <figcaption class="flex items-center justify-between gap-4 p-4 text-sm">
    <span class="font-semibold text-ink">{item.caption}</span>
    <span class="rounded-full bg-shell px-3 py-1 text-xs font-semibold text-harbor">{item.category}</span>
  </figcaption>
</figure>
