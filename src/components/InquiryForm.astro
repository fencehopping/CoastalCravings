---
const eventTypes = ['Birthday', 'Beach day', 'Shower', 'Corporate', 'Holiday', 'Date night', 'Wedding', 'Other'];
const interests = ['Small board', 'Gathering board', 'Party board', 'Grazing table', 'Custom / unsure'];
const budgets = ['$75-$150', '$150-$300', '$300-$600', '$600+'];
const vibes = ['Coastal', 'Colorful', 'Classic', 'Romantic', 'Kid-friendly', 'Upscale', 'Seasonal', 'Custom'];
const sources = ['Instagram', 'Friend/referral', 'Google', 'Event', 'Other'];

const inputClass =
  'focus-ring min-h-12 w-full rounded-lg border border-harbor/15 bg-white px-4 py-3 text-sm text-ink shadow-sm placeholder:text-ink/35';
const labelClass = 'mb-2 block text-sm font-semibold text-ink';
---

<div class="rounded-lg border border-harbor/10 bg-white p-5 shadow-soft sm:p-8">
  <form class="grid gap-5" data-inquiry-form action="#" method="post">
    <div class="grid gap-5 md:grid-cols-2">
      <label>
        <span class={labelClass}>Name</span>
        <input class={inputClass} name="name" autocomplete="name" required />
      </label>
      <label>
        <span class={labelClass}>Email</span>
        <input class={inputClass} name="email" type="email" autocomplete="email" required />
      </label>
      <label>
        <span class={labelClass}>Phone</span>
        <input class={inputClass} name="phone" type="tel" autocomplete="tel" />
      </label>
      <label>
        <span class={labelClass}>Event date</span>
        <input class={inputClass} name="event_date" type="date" />
      </label>
      <label class="md:col-span-2">
        <span class={labelClass}>Event location / town</span>
        <input class={inputClass} name="location" placeholder="Scituate, Cohasset, Hingham..." />
      </label>
      <label>
        <span class={labelClass}>Pickup or delivery preference</span>
        <select class={inputClass} name="fulfillment">
          <option value="">Select a preference</option>
          <option>Pickup</option>
          <option>Delivery</option>
          <option>Unsure</option>
        </select>
      </label>
      <label>
        <span class={labelClass}>Event type</span>
        <select class={inputClass} name="event_type">
          <option value="">Select event type</option>
          {eventTypes.map((option) => <option>{option}</option>)}
        </select>
      </label>
      <label>
        <span class={labelClass}>Estimated guest count</span>
        <input class={inputClass} name="guest_count" inputmode="numeric" placeholder="About 12" />
      </label>
      <label>
        <span class={labelClass}>Interested in</span>
        <select class={inputClass} name="interested_in">
          <option value="">Select an option</option>
          {interests.map((option) => <option>{option}</option>)}
        </select>
      </label>
      <label>
        <span class={labelClass}>Budget range</span>
        <select class={inputClass} name="budget">
          <option value="">Select a range</option>
          {budgets.map((option) => <option>{option}</option>)}
        </select>
      </label>
      <label>
        <span class={labelClass}>Vibe / theme</span>
        <select class={inputClass} name="vibe">
          <option value="">Select a vibe</option>
          {vibes.map((option) => <option>{option}</option>)}
        </select>
      </label>
      <label class="md:col-span-2">
        <span class={labelClass}>Dietary notes</span>
        <textarea class={`${inputClass} min-h-28`} name="dietary_notes" placeholder="Allergies, vegetarian, gluten-free, preferences..."></textarea>
      </label>
      <label class="md:col-span-2">
        <span class={labelClass}>Message / details</span>
        <textarea class={`${inputClass} min-h-32`} name="message" placeholder="Tell us about the occasion, timing, colors, theme, and anything else helpful."></textarea>
      </label>
      <label class="md:col-span-2">
        <span class={labelClass}>How did you hear about us?</span>
        <select class={inputClass} name="source">
          <option value="">Select an option</option>
          {sources.map((option) => <option>{option}</option>)}
        </select>
      </label>
    </div>

    <p class="rounded-lg bg-shell p-4 text-sm leading-6 text-ink/70">
      Submitting this request does not confirm your order. We will follow up to confirm availability, pricing, pickup/delivery details, and deposit information.
    </p>

    <button class="focus-ring min-h-12 rounded-full bg-harbor px-6 py-3 text-sm font-bold text-white transition hover:bg-ink" type="submit">
      Submit request
    </button>
    <p class="hidden rounded-lg border border-sage/25 bg-sage/10 p-4 text-sm font-semibold text-harbor" data-success>
      Thanks - your request was received. We will be in touch soon to confirm the details.
    </p>
  </form>
</div>

<script>
  const form = document.querySelector('[data-inquiry-form]');
  const success = document.querySelector('[data-success]');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    success?.classList.remove('hidden');
    success?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
</script>
