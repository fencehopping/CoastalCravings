---
interface Props {
  eyebrow?: string;
  title: string;
  copy?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, copy, align = 'left' } = Astro.props;
---

<div class:list={['max-w-3xl', align === 'center' && 'mx-auto text-center']}>
  {eyebrow && <p class="mb-3 text-xs font-bold uppercase text-cranberry">{eyebrow}</p>}
  <h2 class="font-serif text-4xl font-semibold leading-tight text-ink sm:text-5xl">{title}</h2>
  {copy && <p class="mt-4 text-base leading-7 text-ink/70 sm:text-lg">{copy}</p>}
</div>
