---
import Button from './Button.astro';
---

<section class="bg-harbor py-16 text-white sm:py-20">
  <div class="container-page text-center">
    <p class="text-xs font-bold uppercase text-tide">Plan the spread</p>
    <h2 class="mx-auto mt-4 max-w-3xl font-serif text-4xl font-semibold leading-tight sm:text-5xl">
      Have a date, guest count, or loose idea in mind?
    </h2>
    <p class="mx-auto mt-4 max-w-2xl text-base leading-7 text-white/72">
      Send the details and we will help match the right board, box, or grazing table to your gathering.
    </p>
    <Button class="mt-8 bg-white text-harbor hover:bg-shell" href="/inquiry">Request a Board</Button>
  </div>
</section>
